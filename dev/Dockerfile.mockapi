# Build stage
FROM golang:1.25-alpine AS builder

WORKDIR /build

# Cache module downloads separately from source so rebuilds are fast.
COPY go.mod go.sum ./
RUN go mod download

# Copy only what mockapi needs — avoids rebuilding when unrelated files change.
COPY cmd/mockapi/ cmd/mockapi/
COPY internal/       internal/

RUN CGO_ENABLED=0 go build -ldflags="-s -w" -o /mockapi ./cmd/mockapi

# Runtime stage — minimal image, no shell needed.
FROM gcr.io/distroless/static:nonroot

COPY --from=builder /mockapi /mockapi

ENV PORT=8090
ENV SERVICES_FILE=/data/services.yaml

EXPOSE 8090

ENTRYPOINT ["/mockapi"]
